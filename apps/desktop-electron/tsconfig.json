{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "baseUrl": "."
  },
  "include": [
    "electron",
    "renderer",
    "vite.*.config.ts",
    "forge.config.ts",
    "tests"
  ],
  "exclude": [
    "e2e",
    "node_modules"
  ]
}