{
  "name": "egoistshield-desktop-electron",
  "productName": "EgoistShield",
  "version": "1.8.3",
  "description": "EgoistShield next-gen universal VPN client for Windows",
  "main": ".vite/build/main.js",
  "private": true,
  "author": {
    "name": "EgoistShield Team"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "electron-forge start",
    "generate-icons": "node packaging/scripts/generate-icons.mjs",
    "ensure:runtime": "powershell -ExecutionPolicy Bypass -File ./packaging/scripts/ensure-xray-runtime.ps1 && powershell -ExecutionPolicy Bypass -File ./packaging/scripts/ensure-singbox-runtime.ps1",
    "package": "npm run ensure:runtime && electron-forge package",
    "make": "npm run ensure:runtime && electron-forge make",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "stress": "vitest run tests/stress.spec.ts",
    "build:win": "npm run test && npm run stress && npm run make -- --platform win32",
    "build:installer": "npm run package && electron-builder --config ./packaging/electron-builder.json --win nsis --x64 --prepackaged ./out/EgoistShield-win32-x64",
    "build:single-exe": "powershell -ExecutionPolicy Bypass -File ./packaging/scripts/build-single-exe.ps1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@electron-forge/cli": "7.8.1",
    "@electron-forge/maker-zip": "7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.8.1",
    "@electron-forge/plugin-vite": "7.8.1",
    "@electron-forge/shared-types": "7.8.1",
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "5.1.3",
    "autoprefixer": "^10.4.24",
    "electron": "36.9.5",
    "electron-builder": "25.1.8",
    "jsdom": "^28.1.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "5.8.3",
    "vite": "^7.3.1",
    "vitest": "3.1.2"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.34.2",
    "gsap": "^3.12.7",
    "jsqr": "1.4.0",
    "lucide-react": "0.503.0",
    "react": "19.1.0",
    "react-circle-flags": "^0.0.27",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "yaml": "2.8.1",
    "zod": "^3.24.0",
    "zustand": "5.0.11"
  },
  "overrides": {
    "tar": "^7.4.3",
    "@electron/rebuild": "^3.7.1"
  }
}
